      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：运行数据完整性与泄漏检查\n",
        "# English: Run data integrity and leakage checks\n",
        "run_script([\n",
        "    sys.executable,\n",
        "    \"scripts/01_data_check.py\",\n",
        "    \"--data-dir\", DATA_DIR,\n",
        "    \"--output-dir\", OUTPUT_DIR,\n",
        "])\n"
      ]
    },
