  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# NHANES Hv2 Colab Experiment\n",
        "\n",
        "This notebook only runs experiment code.\n",
        "\n",
        "It does not fabricate results.\n",
        "\n",
        "It does not generate thesis Chapter 4 text.\n",
        "\n",
        "本 notebook 只运行实验代码，不伪造实验结果，也不生成论文第4章正文。\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：挂载 Google Drive\n",
        "# English: Mount Google Drive\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：克隆或更新 GitHub 仓库，并切换到仓库根目录\n",
        "# English: Clone or update the GitHub repository, then switch to the repository root\n",
        "import os\n",
        "import subprocess\n",
        "\n",
        "REPO_URL = \"https://github.com/TiANLANG777/nhanes_2021_2023_health_index_experiment.git\"\n",
        "REPO_DIR = \"/content/nhanes_2021_2023_health_index_experiment\"\n",
        "\n",
        "if not os.path.exists(REPO_DIR):\n",
        "    subprocess.run([\"git\", \"clone\", REPO_URL, REPO_DIR], check=True)\n",
        "else:\n",
        "    subprocess.run([\"git\", \"-C\", REPO_DIR, \"pull\"], check=True)\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "print(f\"Current working directory: {os.getcwd()}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录安装依赖\n",
        "# English: Install dependencies from the repository root\n",
        "import subprocess\n",
        "import sys\n",
        "\n",
        "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-r\", \"requirements_colab.txt\"], cwd=REPO_DIR, check=True)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：定义固定路径、创建输出子文件夹，并准备脚本运行辅助函数\n",
        "# English: Define fixed paths, create output subfolders, and prepare a helper for script execution\n",
        "import os\n",
        "import subprocess\n",
        "import sys\n",
        "\n",
        "PROJECT_DIR = \"/content/drive/MyDrive/nhanes_2021_2023_health_index_experiment\"\n",
        "DATA_DIR = PROJECT_DIR + \"/data\"\n",
        "OUTPUT_DIR = PROJECT_DIR + \"/outputs\"\n",
        "\n",
        "FULL_FEATURE_PATH = DATA_DIR + \"/adult_full_feature_set_v2.csv\"\n",
        "REDUCED_FEATURE_PATH = DATA_DIR + \"/adult_reduced_feature_set_v2.csv\"\n",
        "TARGET_PATH = DATA_DIR + \"/adult_targets_v2.csv\"\n",
        "\n",
        "for required_path in [FULL_FEATURE_PATH, REDUCED_FEATURE_PATH, TARGET_PATH]:\n",
        "    if not os.path.exists(required_path):\n",
        "        raise FileNotFoundError(f\"Missing required file: {required_path}\")\n",
        "\n",
        "for subdir in [\"tables\", \"figures\", \"models\", \"reports\"]:\n",
        "    os.makedirs(os.path.join(OUTPUT_DIR, subdir), exist_ok=True)\n",
        "\n",
        "def run_script(command, description):\n",
        "    \"\"\"中文：从仓库根目录运行脚本并打印运行信息。\n",
        "    English: Run a script from the repository root and print the execution message.\n",
        "    \"\"\"\n",
        "    os.chdir(REPO_DIR)\n",
        "    print(description)\n",
        "    print(\" \\".join(command))\n",
        "    subprocess.run(command, cwd=REPO_DIR, check=True)\n",
        "\n",
        "print(PROJECT_DIR)\n",
        "print(DATA_DIR)\n",
        "print(OUTPUT_DIR)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录运行数据完整性与泄漏检查\n",
        "# English: Run data integrity and leakage checks from the repository root\n",
        "import os\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "run_script(\n",
        "    [\n",
        "        sys.executable,\n",
        "        \"scripts/01_data_check.py\",\n",
        "        \"--data-dir\",\n",
        "        DATA_DIR,\n",
        "        \"--output-dir\",\n",
        "        OUTPUT_DIR,\n",
        "    ],\n",
        "    \"Running data integrity and leakage checks\",\n",
        ")\n",
        "\n",
        "with open(os.path.join(OUTPUT_DIR, \"data_check\", \"data_check_report.md\"), \"r\", encoding=\"utf-8\") as handle:\n",
        "    print(handle.read())\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：按 feature set 和单模型分段运行 H_v2 回归，以适配 Colab 中断后续跑\n",
        "# English: Run H_v2 regression one model at a time for each feature set so Colab reruns can resume safely\n",
        "import subprocess\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "hv2_models = [\"ridge\", \"elastic_net\", \"gradient_boosting\", \"random_forest\", \"xgboost\", \"lightgbm\"]\n",
        "\n",
        "for feature_set in [\"full\", \"reduced\"]:\n",
        "    for model in hv2_models:\n",
        "        description = f\"Running H_v2 regression: feature_set={feature_set}, model={model}\"\n",
        "        command = [\n",
        "            sys.executable,\n",
        "            \"scripts/02_train_hv2_regression.py\",\n",
        "            \"--feature-set\",\n",
        "            feature_set,\n",
        "            \"--model\",\n",
        "            model,\n",
        "            \"--data-dir\",\n",
        "            DATA_DIR,\n",
        "            \"--output-dir\",\n",
        "            OUTPUT_DIR,\n",
        "        ]\n",
        "        try:\n",
        "            run_script(command, description)\n",
        "        except subprocess.CalledProcessError as exc:\n",
        "            print(f\"Model command failed and the notebook will continue: {exc}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录运行年龄组稳定性分析\n",
        "# English: Run age-group stability analysis from the repository root\n",
        "import os\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "for feature_set in [\"full\", \"reduced\"]:\n",
        "    run_script(\n",
        "        [\n",
        "            sys.executable,\n",
        "            \"scripts/03_age_group_stability.py\",\n",
        "            \"--feature-set\",\n",
        "            feature_set,\n",
        "            \"--model\",\n",
        "            \"random_forest\",\n",
        "            \"--data-dir\",\n",
        "            DATA_DIR,\n",
        "            \"--output-dir\",\n",
        "            OUTPUT_DIR,\n",
        "        ],\n",
        "        f\"Running age-group stability: feature_set={feature_set}, model=random_forest\",\n",
        "    )\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录运行 H_v1 敏感性分析\n",
        "# English: Run H_v1 sensitivity analysis from the repository root\n",
        "import os\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "for feature_set in [\"full\", \"reduced\"]:\n",
        "    run_script(\n",
        "        [\n",
        "            sys.executable,\n",
        "            \"scripts/04_hv1_sensitivity.py\",\n",
        "            \"--feature-set\",\n",
        "            feature_set,\n",
        "            \"--model\",\n",
        "            \"random_forest\",\n",
        "            \"--data-dir\",\n",
        "            DATA_DIR,\n",
        "            \"--output-dir\",\n",
        "            OUTPUT_DIR,\n",
        "        ],\n",
        "        f\"Running H_v1 sensitivity: feature_set={feature_set}, model=random_forest\",\n",
        "    )\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录运行 SHAP 分析，并将其视为相关性解释而非因果解释\n",
        "# English: Run SHAP analysis from the repository root and treat it as an association-based explanation, not a causal explanation\n",
        "import os\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "run_script(\n",
        "    [\n",
        "        sys.executable,\n",
        "        \"scripts/05_shap_analysis.py\",\n",
        "        \"--feature-set\",\n",
        "        \"full\",\n",
        "        \"--data-dir\",\n",
        "        DATA_DIR,\n",
        "        \"--output-dir\",\n",
        "        OUTPUT_DIR,\n",
        "    ],\n",
        "    \"Running SHAP analysis: feature_set=full\",\n",
        ")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：从仓库根目录生成实验总结\n",
        "# English: Generate the experiment summary from the repository root\n",
        "import os\n",
        "\n",
        "os.chdir(REPO_DIR)\n",
        "run_script(\n",
        "    [\n",
        "        sys.executable,\n",
        "        \"scripts/06_generate_experiment_summary.py\",\n",
        "        \"--output-dir\",\n",
        "        OUTPUT_DIR,\n",
        "    ],\n",
        "    \"Generating experiment summary\",\n",
        ")\n",
        "\n",
        "with open(os.path.join(OUTPUT_DIR, \"experiment_summary\", \"experiment_summary.md\"), \"r\", encoding=\"utf-8\") as handle:\n",
        "    print(handle.read())\n"
      ]
    }
