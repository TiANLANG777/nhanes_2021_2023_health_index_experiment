        "# NHANES Formal Experiment Notebook\n",
        "\n",
        "- This notebook runs the formal experiment.\n",
        "- It does not fabricate results.\n",
        "- It does not generate thesis Chapter 4 text.\n",
        "- All outputs are saved to Google Drive.\n",
        "- If Colab disconnects, rerun the recovery cells and continue from unfinished steps.\n",
        "\n",
        "Recommended execution:\n",
        "1. Run recovery setup.\n",
        "2. Run status check.\n",
        "3. Run missing steps only.\n",
        "4. Do not run all cells at once on Colab Free.\n",
        "\n",
        "推荐执行方式：先恢复环境，再检查状态，只补跑未完成步骤，不要在 Colab Free 上一次性运行全部单元。\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：恢复 Google Drive、仓库和 Python 环境\n",
        "# English: Recover Google Drive, repository, and Python environment\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "import os, sys, subprocess, json, time\n",
        "from pathlib import Path\n",
        "\n",
        "REPO_URL = \"https://github.com/TiANLANG777/nhanes_2021_2023_health_index_experiment.git\"\n",
        "REPO_DIR = \"/content/nhanes_2021_2023_health_index_experiment\"\n",
        "\n",
        "if not os.path.exists(REPO_DIR):\n",
        "    !git clone https://github.com/TiANLANG777/nhanes_2021_2023_health_index_experiment.git /content/nhanes_2021_2023_health_index_experiment\n",
        "else:\n",
        "    %cd /content/nhanes_2021_2023_health_index_experiment\n",
        "    !git pull\n",
        "\n",
        "%cd /content/nhanes_2021_2023_health_index_experiment\n",
        "\n",
        "!pip install -r requirements_colab.txt\n",
        "\n",
        "PROJECT_DIR = \"/content/drive/MyDrive/nhanes_2021_2023_health_index_experiment\"\n",
        "DATA_DIR = f\"{PROJECT_DIR}/data\"\n",
        "OUTPUT_DIR = f\"{PROJECT_DIR}/outputs\"\n",
        "\n",
        "for subdir in [\n",
        "    \"tables\",\n",
        "    \"figures\",\n",
        "    \"models\",\n",
        "    \"reports\",\n",
        "    \"hv2_training\",\n",
        "    \"hv1_sensitivity\",\n",
        "    \"shap\"\n",
        "]:\n",
        "    os.makedirs(f\"{OUTPUT_DIR}/{subdir}\", exist_ok=True)\n",
        "\n",
        "print(\"Recovery setup completed.\")\n",
        "print(\"Repository:\", REPO_DIR)\n",
        "print(\"Data:\", DATA_DIR)\n",
        "print(\"Outputs:\", OUTPUT_DIR)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：定义通用脚本运行函数，完整显示 stdout 和 stderr\n",
        "# English: Define a shared script runner that prints full stdout and stderr\n",
        "def run_script(command):\n",
        "    import subprocess, shlex\n",
        "    print(\"Running command:\")\n",
        "    print(\" \\".join(command))\n",
        "    result = subprocess.run(\n",
        "        command,\n",
        "        text=True,\n",
        "        stdout=subprocess.PIPE,\n",
        "        stderr=subprocess.PIPE\n",
        "    )\n",
        "    print(\"STDOUT:\")\n",
        "    print(result.stdout)\n",
        "    print(\"STDERR:\")\n",
        "    print(result.stderr)\n",
        "    if result.returncode != 0:\n",
        "        raise RuntimeError(f\"Command failed with return code {result.returncode}\")\n",
        "    return result\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 中文：检查关键输出文件是否已经生成\n",
        "# English: Check whether key output files already exist\n",
        "import pandas as pd\n",
        "from IPython.display import display\n",
        "\n",
        "status_paths = [\n",
        "    f\"{OUTPUT_DIR}/reports/data_integrity_report.md\",\n",
        "    f\"{OUTPUT_DIR}/tables/leakage_check.csv\",\n",
        "    f\"{OUTPUT_DIR}/tables/hv2_model_comparison.csv\",\n",
        "    f\"{OUTPUT_DIR}/hv2_training/full/leaderboard.csv\",\n",
        "    f\"{OUTPUT_DIR}/hv2_training/reduced/leaderboard.csv\",\n",
        "    f\"{OUTPUT_DIR}/tables/age_group_stability.csv\",\n",
        "    f\"{OUTPUT_DIR}/tables/hv1_sensitivity_model_comparison.csv\",\n",
        "    f\"{OUTPUT_DIR}/tables/shap_feature_importance.csv\",\n",
        "    f\"{OUTPUT_DIR}/figures/model_comparison_rmse.png\",\n",
        "    f\"{OUTPUT_DIR}/figures/predicted_vs_actual_full.png\",\n",
        "    f\"{OUTPUT_DIR}/figures/residual_distribution_full.png\",\n",
        "    f\"{OUTPUT_DIR}/figures/age_group_stability_mae.png\",\n",
        "    f\"{OUTPUT_DIR}/figures/shap_bar.png\",\n",
        "    f\"{OUTPUT_DIR}/figures/shap_summary.png\",\n",
        "    f\"{OUTPUT_DIR}/reports/experiment_summary.md\",\n",
        "]\n",
        "\n",
        "status_frame = pd.DataFrame({\n",
        "    \"file_path\": status_paths,\n",
        "    \"exists\": [os.path.exists(path) for path in status_paths],\n",
        "})\n",
        "display(status_frame)\n"
      ]
    },
